import os
import h5py
import numpy as np
import pandas as pd

def load_cleaned_light_curve(file_path):
    """
    Loads cleaned time-series starlight data from an HDF5 file.
    
    Parameters:
    file_path (str): Path to the target .h5 file.
                     
    Returns:
    pd.DataFrame: A structured dataframe containing 'time' and 'flux'
    """
    if not os.path.exists(file_path):
        raise FileNotFoundError(f"Target data file not found at: {file_path}")
        
    with h5py.File(file_path, 'r') as f:
        # Extract the core arrays provided by the Data Engineer
        time = np.array(f['time'])
        flux = np.array(f['flux'])
        
        # Capture metadata if provided (e.g., Star ID, Right Ascension, Declination)
        star_id = f.attrs.get('star_id', 'Unknown_Target')
    
    # Drop any leftover NaN values safely using vectorized numpy operations
    valid_mask = ~np.isnan(time) & ~np.isnan(flux)
    time = time[valid_mask]
    flux = flux[valid_mask]
    
    # Structure into a Pandas DataFrame for downstream manipulation
    df = pd.DataFrame({
        'time': time,
        'flux': flux
    })
    
    print(f"[SUCCESS] Loaded target {star_id}: {len(df)} data points remaining after masking.")
    return df

